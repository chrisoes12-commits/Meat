  <div style=\"font-size:12.5px;font-weight:800;color:#15233B\">Grain Fed<\u002Fdiv>\n                <div style=\"font-size:10px;font-weight:700;color:#AEB8C7;text-transform:uppercase;letter-spacing:.06em\">Grain finished<\u002Fdiv>\n              <\u002Fdiv>\n              <div style=\"background:#fff;padding:12px;text-align:center;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:3px;min-height:62px\">\n                <div style=\"font-size:12.5px;font-weight:800;color:#15233B\">Wagyu<\u002Fdiv>\n                <div style=\"font-size:10px;font-weight:700;color:#AEB8C7;text-transform:uppercase;letter-spacing:.06em\">Marbled premium<\u002Fdiv>\n              <\u002Fdiv>\n            <\u002Fdiv>\n\n            <sc-for list=\"{{ rows }}\" as=\"row\" hint-placeholder-count=\"4\">\n              <div style=\"display:grid;grid-template-columns:134px 1fr 1fr 1fr;gap:1px;background:#E7EBF2\">\n                <div style=\"background:#fff;display:flex;align-items:center;gap:11px;padding:0 15px;min-height:128px\">\n                  <div style=\"{{ row.railStyle }}\"><\u002Fdiv>\n                  <div style=\"display:flex;flex-direction:column;gap:3px\">\n                    <div style=\"font-size:13.5px;font-weight:800;color:#15233B;letter-spacing:-.01em;line-height:1.15\">{{ row.label }}<\u002Fdiv>\n                    <div style=\"font-size:10px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:#AEB8C7\">{{ row.note }}<\u002Fdiv>\n                  <\u002Fdiv>\n                <\u002Fdiv>\n                <sc-for list=\"{{ row.cells }}\" as=\"cell\" hint-placeholder-count=\"3\">\n                  <div style=\"{{ cell.style }}\" ondragover=\"{{ cell.onOver }}\" ondrop=\"{{ cell.onDrop }}\">\n                    <sc-for list=\"{{ cell.brands }}\" as=\"b\" hint-placeholder-count=\"0\">\n                      <div draggable=\"true\" ondragstart=\"{{ b.onDragStart }}\" ondragend=\"{{ onDragEnd }}\" style=\"{{ b.style }}\" style-hover=\"box-shadow:0 6px 16px rgba(20,35,59,.18);transform:translateY(-2px)\">\n                        {{ b.img }}\n                        <span style=\"{{ b.badgeStyle }}\">{{ b.badge }}<\u002Fspan>\n                      <\u002Fdiv>\n                    <\u002Fsc-for>\n                  <\u002Fdiv>\n                <\u002Fsc-for>\n              <\u002Fdiv>\n            <\u002Fsc-for>\n          <\u002Fdiv>\n\n          <div style=\"display:flex;align-items:center;gap:11px;margin-top:18px;flex-wrap:wrap\">\n            <button onclick=\"{{ checkS1 }}\" style=\"appearance:none;border:none;cursor:pointer;font-family:inherit;font-size:14px;font-weight:700;padding:11px 22px;border-radius:9px;background:var(--accent,#2E5CA8);color:#fff;box-shadow:0 1px 2px rgba(20,35,59,.14)\" style-hover=\"background:var(--accent-dark,#21478A)\">Check Answers<\u002Fbutton>\n            <button onclick=\"{{ resetS1 }}\" style=\"appearance:none;cursor:pointer;font-family:inherit;font-size:14px;font-weight:600;padding:11px 20px;border-radius:9px;background:#fff;color:#15233B;border:1px solid #DCE2EC\" style-hover=\"background:#F4F7FB;border-color:#CBD4E1\">Reset<\u002Fbutton>\n            <sc-if value=\"{{ s1msg }}\" hint-placeholder-val=\"{{ false }}\">\n              <span style=\"{{ s1scoreStyle }}\">{{ s1msg }}<\u002Fspan>\n            <\u002Fsc-if>\n          <\u002Fdiv>\n        <\u002Fdiv>\n      <\u002Fsc-if>\n\n      <sc-if value=\"{{ isS2 }}\" hint-placeholder-val=\"{{ false }}\">\n        <div>\n          <div style=\"display:flex;gap:11px;align-items:flex-start;padding:2px 0 18px;color:#5A6A82;font-size:13.5px;line-height:1.5;max-width:760px\">\n            <span style=\"flex-shrink:0;width:22px;height:22px;border-radius:50%;background:var(--accent-soft,#EEF3FB);color:var(--accent-dark,#21478A);display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:800;font-style:italic;margin-top:1px\">i<\u002Fspan>\n            <span>For each MOCO house brand, select the correct <strong style=\"color:#15233B\">beef category<\u002Fstrong> and <strong style=\"color:#15233B\">tier level<\u002Fstrong>, then press Check Answers.<\u002Fspan>\n          <\u002Fdiv>\n\n          <div style=\"display:flex;gap:16px;flex-wrap:wrap\">\n            <sc-for list=\"{{ houseCards }}\" as=\"b\" hint-placeholder-count=\"0\">\n              <div style=\"flex:1 1 300px;min-width:280px;background:#fff;border:1px solid #E6EAF1;border-radius:14px;padding:18px;display:flex;flex-direction:column;gap:15px;box-shadow:0 1px 2px rgba(20,35,59,.04)\">\n                <div style=\"height:104px;background:#F7F9FC;border:1px solid #EEF1F6;border-radius:11px;display:flex;align-items:center;justify-content:center;padding:16px\">\n                  {{ b.img }}\n                <\u002Fdiv>\n                <div>\n                  <div style=\"font-size:11px;font-weight:800;text-transform:uppercase;letter-spacing:.07em;color:#93A0B2;margin-bottom:9px\">Beef Category<\u002Fdiv>\n                  <div style=\"display:flex;flex-wrap:wrap;gap:7px\">\n                    <sc-for list=\"{{ b.colPills }}\" as=\"p\" hint-placeholder-count=\"3\">\n                      <button onclick=\"{{ p.onClick }}\" style=\"{{ p.style }}\">{{ p.label }}<\u002Fbutton>\n                    <\u002Fsc-for>\n                  <\u002Fdiv>\n                <\u002Fdiv>\n                <div>\n                  <div style=\"font-size:11px;font-weight:800;text-transform:uppercase;letter-spacing:.07em;color:#93A0B2;margin-bottom:9px\">Tier Level<\u002Fdiv>\n                  <div style=\"display:flex;flex-wrap:wrap;gap:7px\">\n                    <sc-for list=\"{{ b.tierPills }}\" as=\"p\" hint-placeholder-count=\"4\">\n                      <button onclick=\"{{ p.onClick }}\" style=\"{{ p.style }}\">{{ p.label }}<\u002Fbutton>\n                    <\u002Fsc-for>\n                  <\u002Fdiv>\n                <\u002Fdiv>\n                <sc-if value=\"{{ b.feedback }}\" hint-placeholder-val=\"{{ false }}\">\n                  <div style=\"{{ b.feedbackStyle }}\"><span style=\"font-weight:800\">{{ b.feedbackIcon }}<\u002Fspan>{{ b.feedback }}<\u002Fdiv>\n                <\u002Fsc-if>\n              <\u002Fdiv>\n            <\u002Fsc-for>\n          <\u002Fdiv>\n\n          <div style=\"display:flex;align-items:center;gap:11px;margin-top:20px;flex-wrap:wrap\">\n            <button onclick=\"{{ checkS2 }}\" style=\"appearance:none;border:none;cursor:pointer;font-family:inherit;font-size:14px;font-weight:700;padding:11px 22px;border-radius:9px;background:var(--accent,#2E5CA8);color:#fff;box-shadow:0 1px 2px rgba(20,35,59,.14)\" style-hover=\"background:var(--accent-dark,#21478A)\">Check Answers<\u002Fbutton>\n            <button onclick=\"{{ resetS2 }}\" style=\"appearance:none;cursor:pointer;font-family:inherit;font-size:14px;font-weight:600;padding:11px 20px;border-radius:9px;background:#fff;color:#15233B;border:1px solid #DCE2EC\" style-hover=\"background:#F4F7FB;border-color:#CBD4E1\">Reset<\u002Fbutton>\n            <sc-if value=\"{{ s2msg }}\" hint-placeholder-val=\"{{ false }}\">\n              <span style=\"{{ s2scoreStyle }}\">{{ s2msg }}<\u002Fspan>\n            <\u002Fsc-if>\n          <\u002Fdiv>\n        <\u002Fdiv>\n      <\u002Fsc-if>\n\n    <\u002Fdiv>\n  <\u002Fdiv>\n  <div style=\"max-width:1200px;margin:14px auto 0;text-align:center;font-size:11.5px;color:#AEB8C7;font-weight:600;letter-spacing:.02em\">MOCO Meat · Brand Hierarchy Training · Internal Use Only<\u002Fdiv>\n<\u002Fdiv>\n<\u002Fx-dc>\n<script type=\"text/x-dc\" data-dc-script=\"\" data-props=\"{\n  &quot;accent&quot;: { &quot;editor&quot;: &quot;color&quot;, &quot;default&quot;: &quot;#2E5CA8&quot;, &quot;tsType&quot;: &quot;string&quot; },\n  &quot;revealAnswers&quot;: { &quot;editor&quot;: &quot;boolean&quot;, &quot;default&quot;: true, &quot;tsType&quot;: &quot;boolean&quot; },\n  &quot;showProgress&quot;: { &quot;editor&quot;: &quot;boolean&quot;, &quot;default&quot;: true, &quot;tsType&quot;: &quot;boolean&quot; },\n  &quot;shuffleOnReset&quot;: { &quot;editor&quot;: &quot;boolean&quot;, &quot;default&quot;: true, &quot;tsType&quot;: &quot;boolean&quot; }\n}\">\nclass Component extends DCLogic {\n  rootRef = React.createRef();\n  state = {\n    tab: 's1',\n    loaded: false,\n    order: [],\n    placement: {},\n    checked1: {},\n    s1msg: null, s1perfect: false,\n    sel: {},\n    checked2: {},\n    s2msg: null, s2perfect: false,\n    overZone: null,\n  };\n\n  componentDidMount(){\n    this.applyTheme();\n    this._poll(0);\n  }\n  componentDidUpdate(){ this.applyTheme(); }\n\n  // ── Theme (accent applied via CSS vars so literal styles paint instantly) ──\n  applyTheme(){\n    const el = this.rootRef.current; if(!el) return;\n    const a = this.props.accent || '#2E5CA8';\n    el.style.setProperty('--accent', a);\n    el.style.setProperty('--accent-dark', this._mix(a, '#000000', 0.20));\n    el.style.setProperty('--accent-soft', this._mix(a, '#ffffff', 0.90));\n  }\n  _hex(c){ c=(c||'').replace('#',''); if(c.length===3) c=c.split('').map(function(x){return x+x;}).join(''); return [parseInt(c.slice(0,2),16),parseInt(c.slice(2,4),16),parseInt(c.slice(4,6),16)]; }\n  _mix(a,b,t){ try{ const A=this._hex(a), B=this._hex(b); const r=A.map(function(v,i){return Math.round(v+(B[i]-v)*t);}); return '#'+r.map(function(x){return x.toString(16).padStart(2,'0');}).join(''); }catch(e){ return a; } }\n\n  // ── Data load ──\n  _poll(n){\n    const d = window.BRAND_QUIZ_DATA;\n    if(d && d.BRANDS){ this.BRANDS = d.BRANDS; this.HOUSE = d.HOUSE_BRANDS; this._init(); return; }\n    if(n < 120) setTimeout(()=>this._poll(n+1), 50);\n  }\n  _shuffle(a){ a = a.slice(); for(let i=a.length-1;i>0;i--){ const j=Math.floor(Math.random()*(i+1)); const t=a[i]; a[i]=a[j]; a[j]=t; } return a; }\n  _init(){\n    const order = this._shuffle(this.BRANDS.map(function(b){return b.id;}));\n    const placement = {}; this.BRANDS.forEach(function(b){ placement[b.id]='tray'; });\n    this.setState({ order, placement, checked1:{}, sel:{}, checked2:{}, s1msg:null, s2msg:null, s1perfect:false, s2perfect:false, loaded:true });\n  }\n\n  // ── Drag & drop (section 1) ──\n  onDragStart = (e, id) => { e.dataTransfer.setData('text/plain', id); e.dataTransfer.effectAllowed='move'; this._drag = id; };\n  onDragEnd = () => { if(this.state.overZone !== null) this.setState({ overZone:null }); };\n  onZoneOver = (e, zone) => { e.preventDefault(); try{ e.dataTransfer.dropEffect='move'; }catch(_){} if(this.state.overZone !== zone) this.setState({ overZone:zone }); };\n  onDrop = (e, zone) => {\n    e.preventDefault();\n    const id = e.dataTransfer.getData('text/plain') || this._drag;\n    if(!id) { this.setState({ overZone:null }); return; }\n    this.setState(function(s){\n      const placement = Object.assign({}, s.placement); placement[id] = zone;\n      const checked1 = Object.assign({}, s.checked1); delete checked1[id];\n      return { placement, checked1, overZone:null };\n    });\n  };\n\n  checkS1 = () => {\n    const placement = this.state.placement; const checked1 = {}; let correct=0, placed=0;\n    this.BRANDS.forEach(function(b){\n      const z = placement[b.id]; if(!z || z==='tray') return; placed++;\n      const ok = z === (b.tier + '-' + b.col);\n      checked1[b.id] = ok ? 'correct' : 'incorrect'; if(ok) correct++;\n    });\n    if(!placed){ this.setState({ s1msg:'Place some logos in the grid first.', s1perfect:false, checked1:{} }); return; }\n    const perfect = correct===placed && placed===this.BRANDS.length;\n    this.setState({ checked1, s1msg: correct + ' / ' + placed + ' correct' + (perfect ? ' — perfect score' : ''), s1perfect: perfect });\n  };\n  resetS1 = () => {\n    const ids = this.BRANDS.map(function(b){return b.id;});\n    const order = (this.props.shuffleOnReset === false) ? ids : this._shuffle(ids);\n    const placement = {}; this.BRANDS.forEach(function(b){ placement[b.id]='tray'; });\n    this.setState({ order, placement, checked1:{}, s1msg:null, s1perfect:false });\n  };\n\n  // ── Multiple choice (section 2) ──\n  pick = (id, group, val) => {\n    this.setState(function(s){\n      const cur = s.sel[id] || {}; const next = Object.assign({}, cur); next[group] = val;\n      const sel = Object.assign({}, s.sel); sel[id] = next;\n      const checked2 = Object.assign({}, s.checked2); delete checked2[id];\n      return { sel, checked2 };\n    });\n  };\n  checkS2 = () => {\n    const sel = this.state.sel; const checked2 = {}; let correct=0, answered=0;\n    this.HOUSE.forEach(function(b){\n      const s = sel[b.id] || {}; if(!s.col && !s.tier) return; answered++;\n      const colOk = s.col===b.col, tierOk = s.tier===b.tier, allOk = colOk && tierOk;\n      if(allOk) correct++; checked2[b.id] = { colOk, tierOk, allOk };\n    });\n    if(!answered){ this.setState({ s2msg:'Answer at least one brand first.', s2perfect:false, checked2:{} }); return; }\n    const perfect = correct===answered && answered===this.HOUSE.length;\n    this.setState({ checked2, s2msg: correct + ' / ' + answered + ' correct' + (perfect ? ' — perfect score' : ''), s2perfect: perfect });\n  };\n  resetS2 = () => this.setState({ sel:{}, checked2:{}, s2msg:null, s2perfect:false });\n\n  // ── Style helpers ──\n  _tabStyle(active){\n    return { appearance:'none', background:'transparent', border:'none', padding:'15px 2px', marginRight:'28px', fontFamily:'inherit', fontSize:'14px', fontWeight:700, cursor:'pointer', color: active ? '#15233B' : '#9AA6B6', borderBottom: active ? '2.5px solid var(--accent,#2E5CA8)' : '2.5px solid transparent', marginBottom:'-1px', letterSpacing:'-.005em', transition:'color .15s' };\n  }\n  _cardStyle(st){\n    const base = { width:'88px', height:'56px', background:'#fff', border:'1.5px solid #E1E6EF', borderRadius:'9px', display:'flex', alignItems:'center', justifyContent:'center', padding:'6px', cursor:'grab', position:'relative', flexShrink:0, userSelect:'none', WebkitUserSelect:'none', boxShadow:'0 1px 2px rgba(20,35,59,.05)', transition:'box-shadow .15s, border-color .15s, transform .12s' };\n    if(st==='correct'){ base.borderColor='#7FCBA0'; base.background='#EDF8F1'; }\n    else if(st==='incorrect'){ base.borderColor='#E7A79F'; base.background='#FBEEEC'; }\n    return base;\n  }\n  _badgeStyle(st){\n    if(!st) return { display:'none' };\n    return { position:'absolute', top:'-7px', right:'-7px', width:'19px', height:'19px', borderRadius:'50%', display:'flex', alignItems:'center', justifyContent:'center', fontSize:'11px', fontWeight:800, color:'#fff', background: st==='correct' ? '#2E9E5B' : '#CE4B3E', boxShadow:'0 1px 3px rgba(20,35,59,.25)', animation:'bq-pop .18s ease-out' };\n  }\n  _cellStyle(over){\n    return { minHeight:'128px', padding:'10px', display:'flex', flexWrap:'wrap', gap:'8px', alignContent:'flex-start', background: over ? 'var(--accent-soft,#EEF3FB)' : '#fff', boxShadow: over ? 'inset 0 0 0 2px var(--accent,#2E5CA8)' : 'none', transition:'background .12s' };\n  }\n  _trayZoneStyle(over){\n    return { display:'flex', flexWrap:'wrap', gap:'9px', minHeight:'96px', padding:'14px', borderRadius:'12px', border:'1.5px dashed ' + (over ? 'var(--accent,#2E5CA8)' : '#D5DDEA'), background: over ? 'var(--accent-soft,#EEF3FB)' : '#FAFBFD', alignContent:'flex-start', transition:'background .12s, border-color .12s' };\n  }\n  _scoreStyle(perfect){\n    return { marginLeft:'auto', display:'inline-flex', alignItems:'center', gap:'7px', padding:'8px 15px', borderRadius:'999px', fontSize:'13.5px', fontWeight:700, fontVariantNumeric:'tabular-nums', color: perfect ? '#1E7A47' : 'var(--accent-dark,#21478A)', background: perfect ? '#EAF6EF' : 'var(--accent-soft,#EEF3FB)', border: '1px solid ' + (perfect ? '#BFE4CD' : 'transparent') };\n  }\n  _pillStyle(group, val, sel, checked, b){\n    const base = { appearance:'none', cursor:'pointer', fontFamily:'inherit', fontSize:'12.5px', fontWeight:600, padding:'7px 13px', borderRadius:'999px', border:'1.5px solid #DCE2EC', background:'#fff', color:'#5A6A82', transition:'all .12s' };\n    const selected = sel && sel[group]===val;\n    const reveal = (this.props.revealAnswers !== false);\n    if(!checked){\n      if(selected){ base.borderColor='var(--accent,#2E5CA8)'; base.background='var(--accent-soft,#EEF3FB)'; base.color='var(--accent-dark,#21478A)'; }\n      return base;\n    }\n    const isCorrectVal = (val === b[group]);\n    if(selected){\n      if(isCorrectVal){ base.borderColor='#7FCBA0'; base.background='#EAF6EF'; base.color='#1E7A47'; }\n      else { base.borderColor='#E7A79F'; base.background='#FBEEEC'; base.color='#B23A2E'; }\n    } else if(isCorrectVal && reveal){\n      base.borderColor='#7FCBA0'; base.borderStyle='dashed'; base.color='#1E7A47';\n    } else {\n      base.opacity = 0.5;\n    }\n    return base;\n  }\n  _cardVM(b, checked1){\n    const st = checked1[b.id] || '';\n    const self = this;\n    return { id:b.id, src:b.src, img:React.createElement('img',{src:b.src,draggable:false,alt:'brand logo',style:{maxWidth:'74px',maxHeight:'44px',objectFit:'contain',display:'block',pointerEvents:'none'}}), style:this._cardStyle(st), badge: st==='correct' ? '✓' : (st==='incorrect' ? '✗' : ''), badgeStyle:this._badgeStyle(st), onDragStart:function(e){ self.onDragStart(e, b.id); } };\n  }\n\n  renderVals(){\n    const S = this.state;\n    const self = this;\n    const BRANDS = this.BRANDS || [];\n    const HOUSE = this.HOUSE || [];\n    const byId = {}; BRANDS.forEach(function(b){ byId[b.id]=b; });\n\n    const TIERS = [\n      { key:'super',   label:'Super Premium', color:'#5B53B0', note:'Top shelf' },\n      { key:'premium', label:'Premium',       color:'#2E5CA8', note:'High-end' },\n      { key:'mid',     label:'Mid-Range',     color:'#2E8C6A', note:'Core range' },\n      { key:'entry',   label:'Entry Level',   color:'#C98A2E', note:'Value' },\n    ];\n    const COLS = ['grass','grain','wagyu'];\n    const COL_OPTS = [['grass','Grass-Pasture'],['grain','Grain Fed'],['wagyu','Wagyu']];\n    const TIER_OPTS = [['super','Super Premium'],['premium','Premium'],['mid','Mid-Range'],['entry','Entry Level']];\n\n    // tray\n    const trayBrands = (S.order || []).filter(function(id){ return S.placement[id]==='tray'; }).map(function(id){ return self._cardVM(byId[id], S.checked1); });\n\n    // grid rows\n    const rows = TIERS.map(function(t){\n      return {\n        label: t.label, note: t.note,\n        railStyle: { width:'4px', height:'36px', borderRadius:'2px', background:t.color, flexShrink:0 },\n        cells: COLS.map(function(col){\n          const key = t.key + '-' + col;\n          const brands = (S.order || []).filter(function(id){ return S.placement[id]===key; }).map(function(id){ return self._cardVM(byId[id], S.checked1); });\n          return {\n            key, brands, style: self._cellStyle(S.overZone===key),\n            onOver: function(e){ self.onZoneOver(e, key); },\n            onDrop: function(e){ self.onDrop(e, key); },\n          };\n        })\n      };\n    });\n\n    // section 2 cards\n    const houseCards = HOUSE.map(function(b){\n      const sel = S.sel[b.id] || {};\n      const checked = S.checked2[b.id];\n      const colPills = COL_OPTS.map(function(o){ return { label:o[1], style:self._pillStyle('col', o[0], sel, checked, b), onClick:function(){ self.pick(b.id,'col',o[0]); } }; });\n      const tierPills = TIER_OPTS.map(function(o){ return { label:o[1], style:self._pillStyle('tier', o[0], sel, checked, b), onClick:function(){ self.pick(b.id,'tier',o[0]); } }; });\n      let feedback=null, feedbackStyle=null, feedbackIcon='';\n      if(checked){\n        feedback = checked.allOk ? 'Correct' : 'Review the highlighted answers';\n        feedbackIcon = checked.allOk ? '✓' : '✗';\n        feedbackStyle = { display:'flex', alignItems:'center', gap:'7px', marginTop:'1px', fontSize:'12.5px', fontWeight:700, color: checked.allOk ? '#1E7A47' : '#B23A2E' };\n      }\n      return { id:b.id, src:b.src, img:React.createElement('img',{src:b.src,alt:'house brand logo',style:{maxWidth:'82%',maxHeight:'66px',objectFit:'contain',display:'block'}}), colPills, tierPills, feedback, feedbackStyle, feedbackIcon };\n    });\n\n    const total = BRANDS.length;\n    const placed = BRANDS.filter(function(b){ const z=S.placement[b.id]; return z && z!=='tray'; }).length;\n    const pct = total ? Math.round(placed/total*100) : 0;\n\n    return {\n      rootRef: this.rootRef,\n      goS1: function(){ self.setState({ tab:'s1' }); },\n      goS2: function(){ self.setState({ tab:'s2' }); },\n      tab1Style: this._tabStyle(S.tab==='s1'),\n      tab2Style: this._tabStyle(S.tab==='s2'),\n      isS1: S.tab==='s1',\n      isS2: S.tab==='s2',\n\n      trayBrands,\n      trayZoneStyle: this._trayZoneStyle(S.overZone==='tray'),\n      onTrayOver: function(e){ self.onZoneOver(e, 'tray'); },\n      onTrayDrop: function(e){ self.onDrop(e, 'tray'); },\n      trayShowPlaceholder: trayBrands.length===0,\n      trayPlaceholder: !S.loaded ? 'Loading brand logos…' : 'All logos placed — ready to check',\n      showProgress: (this.props.showProgress !== false) && S.loaded,\n      placedLabel: placed + ' / ' + total + ' placed',\n      progressBarStyle: { height:'100%', width: pct + '%', background:'var(--accent,#2E5CA8)', borderRadius:'999px', transition:'width .25s ease' },\n      onDragEnd: this.onDragEnd,\n\n      rows,\n      checkS1: this.checkS1, resetS1: this.resetS1,\n      s1msg: S.s1msg, s1scoreStyle: this._scoreStyle(S.s1perfect),\n\n      houseCards,\n      checkS2: this.checkS2, resetS2: this.resetS2,\n      s2msg: S.s2msg, s2scoreStyle: this._scoreStyle(S.s2perfect),\n    };\n  }\n}\n<\u002Fscript>\n\n\n<\u002Fbody><\u002Fhtml>"},"entry":"offline-src"}
